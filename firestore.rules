rules_version = '2';

// ⚠️ Estas reglas son permisivas (cualquiera con la URL de tu proyecto puede leer
// y escribir). Sirven para desarrollar y probar rápido, pero antes de compartir
// la app públicamente deberías agregar autenticación (Firebase Auth) y restringir
// el acceso, por ejemplo exigiendo request.auth != null.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
